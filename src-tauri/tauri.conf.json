{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SQL Studio",
  "version": "1.1.0",
  "identifier": "com.fanxiaofan.sql-studio",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SQL Studio · Archery 可视化客户端",
        "width": 1360,
        "height": 860,
        "minWidth": 960,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
