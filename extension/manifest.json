{
  "manifest_version": 3,
  "name": "SQL Studio for dbadmin",
  "version": "1.0.0",
  "description": "基于 dbadmin(Archery)接口的可视化 SQL 客户端：浏览库表结构、翻页查数据、点击排序、快速筛选、自由 SQL，支持多环境与记住密码。",
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "打开 SQL Studio",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
